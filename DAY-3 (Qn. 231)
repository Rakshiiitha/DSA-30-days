231. Power of Two

Example 1:
Input: n = 1
Output: true
Explanation: 20 = 1

Example 2:
Input: n = 16
Output: true
Explanation: 24 = 16

Example 3:
Input: n = 3
Output: false

SOLUTION:

class Solution {
    public boolean isPowerOfTwo(int n) {
        if(n<=0){
            return false;
        }
        int i=1;
        while(i>0){
            if(n==i){
                return true;
            }
            if(n<i){
                return false;
            }
            i*=2;
        }
         return false;
    }
}
